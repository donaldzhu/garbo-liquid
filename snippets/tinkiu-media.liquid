{% liquid
  assign type = data.type | default: type
  assign url = data.url | default: url
  assign alt = data.meta.alt | default: alt
  assign control = control | default: false
  assign hyperlink = hyperlink | default: hyperlink
%}

{% if hyperlink %}
  <a href="{{ hyperlink }}">
{% endif %}
{% if type == 'image' %}
  <img
    src="{{ url }}"
    alt="{{ alt }}"
    class="tinkiu-media" />
{% elsif type == 'video' %}
  <video
    class="tinkiu-media"
    {% if control %}
    controls
    {% endif %}
    src="{{ url }}"
    autoplay
    muted
    loop
    playsinline></video>
{% endif %}
{% if hyperlink %}
  </a>
{% endif %}