{% assign spaceBefore = spaceBefore | default: false, allow_blank: true %}
{% assign title = title | default: title %}
{% assign smallTitle = smallTitle | default: smallTitle %}
{% assign secondaryTitle = secondaryTitle | default: secondaryTitle %}
{% assign noDot = noDot | default: false %}

<div class="tinkiu-section-header">
  {% if noDot != true %}
    {% render 'tinkiu-dot'
      , spaceBefore: spaceBefore %}
  {% endif %}
  {% if title %}
    <h1>
      {{- title | escape -}}
    </h1>
  {% endif %}
  {% if smallTitle %}
    <h3>{{ smallTitle }}</h3>
  {% endif %}
  {% if secondaryTitle %}
    <h4>{{ secondaryTitle }}</h4>
  {% endif %}
</div>